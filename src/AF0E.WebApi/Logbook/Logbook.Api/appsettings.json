  },
  "ApiKeyAuth": {
    "Enabled": false,
    "HeaderName": "",
    "Key": ""
  },
  "QrzSettings": {
    "ApiUrl": "https://xmldata.qrz.com/xml/current",
    "Username": "",
    "Password": ""
  },
  "DxCluster": {
    "InactivityTimeout": "00:10:00",
    "ReconnectDelay": "00:00:15",
    "MonitorInterval": "00:00:15",
    "SpotMaxAge": "00:30:00",
    "LoginDelay": "00:00:01",
    "MaxSpots": 250,
    "Servers": [
      {
        "Name": "Example cluster",
        "Host": "example.dxcluster.local",
        "Port": 23,
        "Login": "",
        "Password": "",
        "PostLoginCommand": "",
        "Enabled": false
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/logbook-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
